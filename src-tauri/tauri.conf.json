{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YES Master",
  "version": "0.0.0",
  "identifier": "com.albummasteringstudio.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YES Master",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 573
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
